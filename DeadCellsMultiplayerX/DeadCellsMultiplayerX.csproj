<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <ModType>mod</ModType>
    <ModMain>DeadCellsMultiplayerX.ModEntry</ModMain>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <AutoInstallMod Condition="'$(Configuration)' == 'Debug'">true</AutoInstallMod>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Platform>x64</Platform>
    <NoWarn>$(NoWarn);MSB3270</NoWarn>
    <GenerateSinglePakFile>true</GenerateSinglePakFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DeadCellsCoreModding.MDK" Version="1.0.1" />
    <PackageReference Include="Microsoft.Native.Quic.MsQuic.OpenSSL" Version="2.5.8" />
    <PackageReference Include="StbImageSharp" Version="2.30.15" />
    <PackageReference Include="Steamworks.NET" Version="20.2.0" />
    <PackageReference Include="StreamJsonRpc" Version="2.25.25" />

    <ModDependency Include="DebugConsole" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="HashlinkSharp" />
    <Reference Include="ModCore.Native" />
    <Reference Include="DebugConsole" />

    <Reference Include="CoreLibrary">
      <HintPath>libs\CoreLibrary\CoreLibrary.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <OutputFiles Include="msquic.dll" />
    <OutputFiles Include="libs\**\*.dll" />
  </ItemGroup>

  <ItemGroup>
    <None Update="msquic.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Client\Networks\Steam\" />
  </ItemGroup>

  <ItemGroup>
    <PackAssets Include="Assets/**/*" RootInPak="DeadCellsMultiplayerX" />
  </ItemGroup>

  <Target Name="StageNuGetDeps" AfterTargets="Build" BeforeTargets="CopyOutputFiles">
    <MakeDir Directories="libs\StreamJsonRpc;libs\StbImageSharp;libs\Steamworks" />
    <Copy SourceFiles="$(OutputPath)/Steamworks.NET.dll" DestinationFolder="libs\Steamworks\" />
    <Copy SourceFiles="$(OutputPath)/StreamJsonRpc.dll" DestinationFolder="libs\StreamJsonRpc\" />
    <Copy SourceFiles="$(OutputPath)/Nerdbank.MessagePack.dll" DestinationFolder="libs\StreamJsonRpc\" />
    <Copy SourceFiles="$(OutputPath)/Nerdbank.Streams.dll" DestinationFolder="libs\StreamJsonRpc\" />
    <Copy SourceFiles="$(OutputPath)/MessagePack.dll" DestinationFolder="libs\StreamJsonRpc\" />
    <Copy SourceFiles="$(OutputPath)/MessagePack.Annotations.dll" DestinationFolder="libs\StreamJsonRpc\" />
    <Copy SourceFiles="$(OutputPath)/PolyType.dll" DestinationFolder="libs\StreamJsonRpc\" />
    <Copy SourceFiles="$(OutputPath)/Microsoft.NET.StringTools.dll" DestinationFolder="libs\StreamJsonRpc\" />
    <Copy SourceFiles="$(OutputPath)/Microsoft.VisualStudio.Threading.dll" DestinationFolder="libs\StreamJsonRpc\" />
    <Copy SourceFiles="$(OutputPath)/Microsoft.VisualStudio.Validation.dll" DestinationFolder="libs\StreamJsonRpc\" />
    <Copy SourceFiles="$(OutputPath)/StbImageSharp.dll" DestinationFolder="libs\StbImageSharp\" />
    <ItemGroup>
      <OutputFiles Include="libs\**\*.dll" />
    </ItemGroup>
  </Target>

</Project>
